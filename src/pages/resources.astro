---
import BaseLayout from '../layouts/BaseLayout.astro';
import categoriesData from '../data/resources.json';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

interface Resource {
  title: string;
  description: string;
  url: string;
  isNew?: boolean;
  dateAdded?: string;
}

interface ResourceCategory {
  title: string;
  icon: string;
  resources: Resource[];
}

const categories: ResourceCategory[] = categoriesData;
---

<BaseLayout title="Resources - GitHub Copilot" description="Curated resources, documentation, and learning materials for GitHub Copilot in Visual Studio">
  <main class="min-h-screen py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">
          <span class="gradient-text">Resources</span>
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mx-auto">
          Curated links to official documentation, blogs, training, and community resources
        </p>
      </div>

      <!-- Quick Access -->
      <section class="mb-12">
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://github.com/features/copilot"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 bg-accent-cyan text-bg-void font-semibold rounded-lg hover:bg-accent-cyan/90 transition-colors"
          >
            Get GitHub Copilot
          </a>
          <a
            href="https://visualstudio.microsoft.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 border border-accent-violet text-accent-violet font-semibold rounded-lg hover:bg-accent-violet/10 transition-colors"
          >
            Download Visual Studio
          </a>
          <a
            href="https://github.com/features/copilot/whats-new"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 border border-border-default text-text-primary rounded-lg hover:border-accent-cyan hover:text-accent-cyan transition-colors"
          >
            What's New
          </a>
        </div>
      </section>

      <!-- Resource Categories -->
      <div class="space-y-12">
        {categories.map((category) => (
          <section>
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">{category.icon}</span>
              <h2 class="text-2xl font-heading font-semibold text-text-primary">{category.title}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {category.resources.map((resource) => (
                <a
                  href={resource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block p-4 rounded-xl border border-border-default bg-bg-overlay hover:border-accent-cyan transition-all"
                >
                  <div class="flex items-start justify-between gap-2">
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <h3 class="font-semibold text-text-primary group-hover:text-accent-cyan transition-colors">
                          {resource.title}
                        </h3>
                        {resource.isNew && (
                          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-accent-cyan/15 text-accent-cyan border border-accent-cyan/30">
                            New
                          </span>
                        )}
                      </div>
                      <p class="text-sm text-text-muted line-clamp-2">{resource.description}</p>
                    </div>
                    <svg class="w-4 h-4 text-text-muted group-hover:text-accent-cyan flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- Footer CTA -->
      <section class="mt-16 text-center">
        <div class="glass rounded-xl p-8">
          <h2 class="text-xl font-heading font-semibold text-text-primary mb-4">
            Want to see Copilot in action?
          </h2>
          <p class="text-text-secondary mb-6">
            Check out our curated video library with tutorials from Microsoft and GitHub.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href={`${base}videos/`}
              class="inline-flex items-center gap-2 px-6 py-3 bg-accent-cyan text-bg-void font-semibold rounded-lg hover:bg-accent-cyan/90 transition-colors"
            >
              Watch Videos
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a
              href={`${base}whats-new/`}
              class="inline-flex items-center gap-2 px-6 py-3 border border-border-default text-text-primary rounded-lg hover:border-accent-cyan hover:text-accent-cyan transition-colors"
            >
              View Changelog
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
